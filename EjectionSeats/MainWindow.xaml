<Window x:Class="EjectionSeats.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="EjectionSeats: Полное моделирование СМ+РД" Height="800" Width="1100">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ПАНЕЛЬ ВВОДА -->
        <ScrollViewer Grid.Column="0" Background="#EEEEEE">
            <StackPanel Margin="10">
                <Expander Header="САМОЛЕТ И РЕЖИМ" IsExpanded="True" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Скорость Vc (м/с):"/>
                        <TextBox x:Name="txtVc" Text="120" Margin="0,0,0,5"/>
                        <TextBlock Text="Высота H (м):"/>
                        <TextBox x:Name="txtH" Text="2000" Margin="0,0,0,5"/>
                        <TextBlock Text="Угол тангажа (град):"/>
                        <TextBox x:Name="txtPitch" Text="0" Margin="0,0,0,5"/>
                    </StackPanel>
                </Expander>

                <Expander Header="КАТАПУЛЬТНОЕ КРЕСЛО" IsExpanded="True" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Масса M (кг):"/>
                        <TextBox x:Name="txtMass" Text="140" Margin="0,0,0,5"/>
                        <TextBlock Text="Угол установки χ (град):"/>
                        <TextBox x:Name="txtChi" Text="17" Margin="0,0,0,5"/>
                        <TextBlock Text="Момент инерции Jz (кг·м²):"/>
                        <TextBox x:Name="txtJz" Text="25" Margin="0,0,0,5"/>
                    </StackPanel>
                </Expander>

                <!-- ПАРАМЕТРЫ СМ (ФОРМУЛА 7.2, 7.6, 7.15) -->
                <Expander Header="СТРЕЛЯЮЩИЙ МЕХАНИЗМ (СМ)" IsExpanded="True" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Площадь поршня Sсм (м²):"/>
                        <TextBox x:Name="txtS_cm" Text="0,01" Margin="0,0,0,5"/>
                        <TextBlock Text="Ход труб Lсм (м):"/>
                        <TextBox x:Name="txtL_cm" Text="1,2" Margin="0,0,0,5"/>
                        <TextBlock Text="Нач. объем W0 (м³):"/>
                        <TextBox x:Name="txtW0" Text="0,001" Margin="0,0,0,5"/>
                        <TextBlock Text="Температура T1 (K):"/>
                        <TextBox x:Name="txtT1" Text="2400" Margin="0,0,0,5"/>
                        <TextBlock Text="Масса заряда Mз (кг):"/>
                        <TextBox x:Name="txtMz" Text="0,25" Margin="0,0,0,5"/>
                        <TextBlock Text="Газовая постоянная R (Дж/(кг·К)):"/>
                        <TextBox x:Name="txtR" Text="300" Margin="0,0,0,5"/>
                    </StackPanel>
                </Expander>

                <Expander Header="РАКЕТНЫЙ ДВИГАТЕЛЬ (РД)" IsExpanded="True" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Тяга T (Н):"/>
                        <TextBox x:Name="txtThrust" Text="4000" Margin="0,0,0,5"/>
                        <TextBlock Text="Время работы τ (с):"/>
                        <TextBox x:Name="txtTimeRD" Text="0,5" Margin="0,0,0,5"/>
                        <TextBlock Text="Плечо тяги e (м):"/>
                        <TextBox x:Name="txtEcc" Text="0,3" Margin="0,0,0,5"/>
                    </StackPanel>
                </Expander>

                <Expander Header="АЭРОДИНАМИКА" IsExpanded="True" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Коэф. лоб. сопр. Cx:"/>
                        <TextBox x:Name="txtCx" Text="0,85" Margin="0,0,0,5"/>
                        <TextBlock Text="Площадь миделя S (м²):"/>
                        <TextBox x:Name="txtS" Text="0,65" Margin="0,0,0,5"/>
                        <TextBlock Text="Коэф. момента mz:"/>
                        <TextBox x:Name="txtMzCoef" Text="-0,1" Margin="0,0,0,5"/>
                        <TextBlock Text="Характерный размер Lк (м):"/>
                        <TextBox x:Name="txtLk" Text="1,2" Margin="0,0,0,5"/>
                    </StackPanel>
                </Expander>

                <Expander Header="СТАБИЛИЗИРУЮЩИЕ ПАРАШЮТЫ" IsExpanded="True" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Площадь купола Sсс (м²):"/>
                        <TextBox x:Name="txtScc" Text="0,5" Margin="0,0,0,5"/>
                        <TextBlock Text="Коэф. сопр. Cxcc:"/>
                        <TextBox x:Name="txtCxcc" Text="0,7" Margin="0,0,0,5"/>
                        <TextBlock Text="Расстояние до штанги Rcc (м):"/>
                        <TextBox x:Name="txtRcc" Text="1,0" Margin="0,0,0,5"/>
                    </StackPanel>
                </Expander>
                <Expander Header="ОПАСНАЯ ТОЧКА КИЛЯ" IsExpanded="True" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Координата Xотк (м):"/>
                        <TextBox x:Name="txtXotk" Text="-5" Margin="0,0,0,5"/>
                        <TextBlock Text="Координата Yотк (м):"/>
                        <TextBox x:Name="txtYotk" Text="3" Margin="0,0,0,5"/>
                        <TextBlock Text="Координата Zотк (м):"/>
                        <TextBox x:Name="txtZotk" Text="0" Margin="0,0,0,5"/>
                    </StackPanel>
                </Expander>
                <Expander Header="ДОП. АЭРОДИНАМИКА" IsExpanded="True" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Коэф. Cy (при α=0):"/>
                        <TextBox x:Name="txtCy0" Text="0,3" Margin="0,0,0,5"/>
                        <TextBlock Text="Коэф. Cz (при α=0):"/>
                        <TextBox x:Name="txtCz0" Text="0,1" Margin="0,0,0,5"/>
                    </StackPanel>
                </Expander>

                <Expander Header="УГЛЫ САМОЛЁТА" IsExpanded="True" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Крен (град):"/>
                        <TextBox x:Name="txtRoll" Text="0" Margin="0,0,0,5"/>
                        <TextBlock Text="Рыскание (град):"/>
                        <TextBox x:Name="txtYaw" Text="0" Margin="0,0,0,5"/>
                    </StackPanel>
                </Expander>

                <Expander Header="МОМЕНТЫ ИНЕРЦИИ КК" IsExpanded="True" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Jx (кг·м²):"/>
                        <TextBox x:Name="txtJx" Text="200" Margin="0,0,0,5"/>
                        <TextBlock Text="Jy (кг·м²):"/>
                        <TextBox x:Name="txtJy" Text="200" Margin="0,0,0,5"/>
                    </StackPanel>
                </Expander>

                <Expander Header="ПАРАШЮТНАЯ СИСТЕМА" IsExpanded="True" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="Время раскрытия (с):"/>
                        <TextBox x:Name="txtTDeploy" Text="1,5" Margin="0,0,0,5"/>
                        <TextBlock Text="Площадь купола Sосн (м²):"/>
                        <TextBox x:Name="txtSmain" Text="60" Margin="0,0,0,5"/>
                        <TextBlock Text="Коэф. сопр. Cx осн:"/>
                        <TextBox x:Name="txtCxmain" Text="1,2" Margin="0,0,0,5"/>
                        <TextBlock Text="Масса пилота (кг):"/>
                        <TextBox x:Name="txtMpilot" Text="100" Margin="0,0,0,5"/>
                        <TextBlock Text="Время раскрытия купола (с):"/>
                        <TextBox x:Name="txtTDeployRamp" Text="0,5" Margin="0,0,0,5"/>
                        <TextBlock Text="Время симуляции (с):"/>
                        <TextBox x:Name="txtSimTime" Text="10" Margin="0,0,0,5"/>
                    </StackPanel>
                </Expander>
                
                <!-- В конец панели с результатами (после txtMaxHeight) добавьте: -->
                <TextBlock x:Name="txtMinDistance" Text="Мин. расстояние до киля: --" 
           FontWeight="Bold" Foreground="Purple" TextWrapping="Wrap" Margin="0,5,0,0"/>

                <Button x:Name="btnCalculate" Content="ЗАПУСТИТЬ МОДЕЛИРОВАНИЕ" 
                        Height="40" Background="LightGreen" FontWeight="Bold" 
                        Click="BtnCalculate_Click" Margin="0,10,0,0"/>

                <Border Background="#F5F5F5" Padding="5" Margin="0,10,0,0" CornerRadius="3">
                    <StackPanel>
                        <TextBlock x:Name="txtStatus" Text="Статус: Ожидание" 
                                   Margin="0,0,0,3" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock x:Name="txtMaxOverload" Text="Макс. перегрузка: --" 
                                   Margin="0,0,0,3" FontWeight="Bold" Foreground="Red" TextWrapping="Wrap"/>
                        <TextBlock x:Name="txtMaxHeight" Text="Макс. высота подъема: --" 
                                   Margin="0,0,0,0" FontWeight="Bold" Foreground="Blue" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ПРАВАЯ ОБЛАСТЬ: 3D И ГРАФИКИ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 3D ВИД -->
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                        <TextBlock Text="3D Траектория (Наземная СК) | " FontWeight="Bold"/>
                        <TextBlock Text="X - вперед" Foreground="Red" Margin="5,0"/>
                        <TextBlock Text="Y - вверх" Foreground="Green" Margin="5,0"/>
                        <TextBlock Text="Z - вбок" Foreground="Blue" Margin="5,0"/>
                    </StackPanel>
                    <Canvas x:Name="Canvas3D" Grid.Row="1" Background="White"/>
                </Grid>
            </Border>

            <!-- ГРАФИКИ (OXYPLOT) -->
            <Grid Grid.Row="1" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- График скорости -->
                <Grid Grid.Column="0" Margin="0,0,5,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Скорость кресла (м/с)" 
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                    <oxy:PlotView x:Name="PlotVelocity" Grid.Row="1"/>
                </Grid>

                <!-- График перегрузки -->
                <Grid Grid.Column="1" Margin="5,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Перегрузка (ед.)" 
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                    <oxy:PlotView x:Name="PlotOverload" Grid.Row="1"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>