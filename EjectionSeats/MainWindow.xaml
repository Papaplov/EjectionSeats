<Window x:Class="EjectionSeats.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Моделирование траектории катапультного кресла" 
        Height="800" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Панель ввода данных -->
        <Border Grid.Column="0" Background="#F0F0F0" Padding="10" CornerRadius="8" Margin="0,0,10,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Параметры полёта" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                    <TextBlock Text="Высота (м)" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtHeight" Text="5000"/>

                    <TextBlock Text="Скорость (м/с)" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtSpeed" Text="250"/>

                    <TextBlock Text="Угол пикирования (градусы)" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtPitch" Text="0"/>

                    <TextBlock Text="Угол крена (градусы)" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtBank" Text="0"/>

                    <TextBlock Text="Параметры кресла" FontWeight="Bold" FontSize="16" Margin="0,15,0,10"/>

                    <TextBlock Text="Масса (кг)" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtMass" Text="150"/>

                    <TextBlock Text="Площадь миделя (м²)" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtArea" Text="0.8"/>

                    <TextBlock Text="Коэффициент сопротивления Cx" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtCx" Text="0.75"/>

                    <TextBlock Text="Параметры катапульты" FontWeight="Bold" FontSize="16" Margin="0,15,0,10"/>

                    <TextBlock Text="Импульс ракетного двигателя (Н·с)" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtImpulse" Text="18000"/>

                    <TextBlock Text="Время работы двигателя (с)" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtBurnTime" Text="0.25"/>

                    <TextBlock Text="Угол направляющих (градусы от вертикали)" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtRailAngle" Text="15"/>

                    <TextBlock Text="Парашют" FontWeight="Bold" FontSize="16" Margin="0,15,0,10"/>

                    <TextBlock Text="Задержка раскрытия (с)" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtChuteDelay" Text="1.5"/>

                    <TextBlock Text="Площадь парашюта (м²)" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtChuteArea" Text="50"/>

                    <Button x:Name="btnSimulate" Content="Рассчитать траекторию" 
                            Background="#4CAF50" Foreground="White" FontWeight="Bold" FontSize="14"
                            Padding="10" Margin="0,20,0,10" Click="OnSimulateClick"/>

                    <TextBlock x:Name="txtStatus" Text="Готов" Foreground="Gray" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Область визуализации -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Траектория полёта (синий - до парашюта, зелёный - после раскрытия)" 
                       FontWeight="Bold" Margin="0,0,0,5"/>

            <Canvas x:Name="canvasTrajectory" Grid.Row="1" Background="White" 
                    ClipToBounds="True" Width="Auto" Height="Auto"/>
        </Grid>
    </Grid>
</Window>